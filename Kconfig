mainmenu "Mender Reference App"

menu "Mender Reference App"

menuconfig WIFI
bool "Mender App WIFI Configuration"
default n

if WIFI
	config MENDER_APP_WIFI_SSID
		string "WIFI SSID - Network name"
		default "my_network"

	config MENDER_APP_WIFI_PSK
		string "WIFI PSK - Network password key"
		default "secret_passwd"

endif # WIFI

	config MENDER_APP_NOOP_UPDATE_MODULE
		bool "Enable no-op Update Module"
		default n
		help
			An Update Module that does nothing. Useful for inspiration on how to get started writing
			your update module, as an alternative to the built-in zephyr-image Update module configured
			with MENDER_ZEPHYR_IMAGE_UPDATE_MODULE

	config MENDER_APP_SERVER_HOST_ON_PREM_CERT
		string "Path to the DER formatted Mender Server Certificate. Relative to mender-mcu-integration"
		default ""
		help
			When in combination with MENDER_SERVER_HOST_ON_PREM, the Mender Reference App
			will add this credential as the MENDER_NET_CA_CERTIFICATE_TAG_PRIMARY.

endmenu

# Region-dependent mbedTLS static heap. The EU server chain anchors to a
# cross-signed ISRG Root YR that the device must verify against the pinned
# RSA-4096 ISRG Root X1; that RSA-4096 signature verify needs ~5 KB more heap
# than the US chain (all RSA-2048). Measured worst-case footprint over a full
# OTA: EU ~43.3 KB, US ~37 KB. Undersizing manifests as a TLS handshake
# failure -0x2700 (X509 NOT_TRUSTED) from an INSUFFICIENT_MEMORY verify.
# So give EU the bigger pool and leave everything else at the historical 40960.
#
# NOTE: this MUST come before `source "Kconfig.zephyr"`. configdefault inserts
# its defaults ahead of the ones that already exist when it is parsed (textual
# order); placed after the source, the symbol's built-in unconditional
# `default 512` is seen first and wins. Parsed before the source, our defaults
# take priority (the MENDER_SERVER_HOST_EU condition still resolves, since
# configdefaults are applied only once the whole tree is known).
configdefault MBEDTLS_HEAP_SIZE
	default 49152 if MENDER_SERVER_HOST_EU
	default 40960

source "Kconfig.zephyr"
