{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":gitSignOff",
    ":rebaseStalePrs"
  ],
  "reviewers": ["team:client-dependabot-reviewers"],

  "packageRules": [
    {
      // TODO: remove some of these when we ditch dependabot
      "matchCategories": ["python", "docker", "ci"],
      "enabled": false
    },
    {
      // TODO: remove  when we ditch dependabot
      "matchManagers": ["git-submodules"],
      "enabled": false
    },
  ],

  "prHourlyLimit": 0
}
